extends layout

block head
  link(rel="stylesheet" href="/css/transport.css")

block title
  | Transport – NYONDO Hardware

block content
  .page-heading-center.mb-4
    h1
      i.fa-solid.fa-truck
      |  Transport Cost Calculator
    p.text-muted Calculate delivery fees based on purchase amount and distance

  .row.g-4
    .col-lg-5
      .form-card
        h4.mb-4
          i.fa-solid.fa-calculator.me-2(style="color: var(--gold);")
          | Delivery Estimator
        form(method="POST" action="/transport/calculate")
          .mb-4
            label.form-label Total Purchase Amount (UGX)
            .input-group
              span.input-group-text: i.fa-solid.fa-money-bill
              input.form-control(type='number' name='amount' value='500000' step='10000' required)
          .mb-4
            label.form-label Distance from Nansana (km)
            .input-group
              span.input-group-text: i.fa-solid.fa-location-dot
              input.form-control(type='number' name='distance' value='8' step='1' required)
            small.text-muted 📍 Nansana Branch is the starting point
          .mb-4
            label.form-label Customer Name (Optional)
            .input-group
              span.input-group-text: i.fa-solid.fa-user
              input.form-control(type='text' name='customerName' placeholder='Enter customer name for record')
          button.btn-primary.w-100.py-2(type='submit')
            i.fa-solid.fa-calculator.me-2
            |  Calculate &amp; Save Delivery
          .policy-box.mt-4
            h6
              i.fa-solid.fa-circle-info.me-2
              | Delivery Policy
            p.small.mb-1
              | ✅ 
              strong Free delivery
              |  if purchase ≥ 500,000 UGX AND distance ≤ 10km
            p.small.mb-0
              | ✅ Otherwise: 
              strong 30,000 UGX
              |  + 
              strong 1,000 UGX/km
              |  for every km beyond 10km

    .col-lg-7
      .section-card
        .section-head
          h2
            i.fa-solid.fa-clock-rotate-left.me-2(style="color: var(--gold);")
            | Recent Deliveries
          form(method="POST" action="/transport/clear" onsubmit="return confirm('Clear all delivery history?');")
            button.btn-outline.btn-sm(type='submit')
              i.fa-solid.fa-trash-can.me-1
              | Clear History
        .table-responsive
          table.data-table
            thead
              tr
                th Date &amp; Time
                th Customer
                th Amount (UGX)
                th Distance (km)
                th Delivery Fee (UGX)
                th Status
            tbody
              if deliveries && deliveries.length
                each del in deliveries
                  tr
                    td
                      i.fa-regular.fa-calendar.me-1
                      = del.createdAt ? del.createdAt.toLocaleString() : '—'
                    td
                      i.fa-solid.fa-user.me-1
                      = del.customerName || 'Walk-in Customer'
                    td= del.purchaseAmount.toLocaleString()
                    td= del.distance
                    td(class=del.deliveryFee === 0 ? 'text-success fw-bold' : 'text-warning fw-bold')
                      = del.deliveryFee === 0 ? 'Free' : del.deliveryFee.toLocaleString()
                    td
                      span.status-pill(class=del.deliveryFee === 0 ? 'sp-paid' : 'sp-pending')
                        = del.deliveryFee === 0 ? 'Free' : 'Paid'
              else
                tr
                  td(colspan='6').text-center No delivery records yet.
        .table-footer.p-3.border-top
          .row.g-3
            .col-md-4
              small.text-muted.d-block Total Deliveries
              strong= totalDeliveries || 0
            .col-md-4
              small.text-muted.d-block Total Collection
              strong= (totalCollection || 0).toLocaleString() + ' UGX'
            .col-md-4
              small.text-muted.d-block Free Deliveries
              strong= freeDeliveries || 0