extends layout

block head
  link(rel="stylesheet" href="/css/inventory.css")

block title
  | Inventory – NYONDO Hardware

block content
  .page-heading-center.mb-4
    h1
      i.fa-solid.fa-boxes-stacked
      |  Inventory Management
    p.text-muted Track stock levels, add stock, and view transaction history

  // Stats Cards
  .row.g-4.mb-4
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-cubes.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Total SKUs
        h3= totalSkus || 0
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-arrow-down-wide-short.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Low Stock Items (&lt;15)
        h3.text-warning= lowStockCount || 0
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-circle-exclamation.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Out of Stock
        h3.text-danger= outOfStockCount || 0
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-chart-line.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Total Stock Value
        h3= (totalStockValue || 0).toLocaleString() + ' UGX'

  // Action Buttons (icons + text)
  .d-flex.flex-wrap.gap-3.mb-4
    a.btn-primary.px-4.py-2(href="/inventory/new")
      i.fa-solid.fa-plus-circle.me-2
      | Add New Product
    a.btn-primary.px-4.py-2(href="/inventory/add-stock")
      i.fa-solid.fa-cart-plus.me-2
      | Add Stock
    a.btn-primary.px-4.py-2(href="/inventory/transactions")
      i.fa-solid.fa-clock-rotate-left.me-2
      | Stock Transactions

  // Product List Table
  .section-card
    .section-head
      h2
        i.fa-solid.fa-list.me-2(style="color: var(--gold);")
        | Product List
    .table-responsive
      table.data-table
        thead
          tr
            th Product
            th Category
            th Stock
            th Unit Price (UGX)
            th Supplier
            th Date Recorded
            th Recorded By
            th Status
            th Actions
        tbody
          if products && products.length
            each prod in products
              - const isLow = prod.currentStock < 15 && prod.currentStock > 0
              - const out = prod.currentStock === 0
              - let statusText = 'In Stock'
              - let statusClass = 'sp-paid'
              if out
                statusText = 'Out of Stock'
                statusClass = 'sp-credit'
              else if isLow
                statusText = 'Low Stock'
                statusClass = 'sp-pending'
              tr
                td
                  i.fa-solid.fa-cube.me-2(style="color: var(--gold);")
                  = prod.productName
                td= prod.category || '—'
                td(class=isLow || out ? 'fw-bold text-warning' : '')= prod.currentStock
                td= prod.unitPrice.toLocaleString()
                td= prod.supplier || '—'
                td= prod.createdAt ? prod.createdAt.toLocaleDateString() : '—'
                td= prod.createdBy ? prod.createdBy.fullName : '—'
                td
                  span.status-pill(class=statusClass)= statusText
                td.actions
                  a.btn-link.me-2(href=`/inventory/${prod._id}/edit`)
                    i.fa-regular.fa-pen-to-square
                  form.d-inline(method="POST" action=`/inventory/${prod._id}/delete` onsubmit="return confirm('Delete this product?')")
                    button.btn-link(type="submit" style="background:none; border:none; padding:0; color:#dc3545;")
                      i.fa-regular.fa-trash-can
          else
            tr
              td(colspan='9').text-center No products found.

  // Low Stock Alerts (only stock < 15)
  .section-card.mt-4
    .section-head
      h2
        i.fa-solid.fa-triangle-exclamation.me-2(style="color: var(--gold);")
        | Low Stock Alerts (Stock &lt; 15 units)
    .p-3
      if lowStockItems && lowStockItems.length
        each item in lowStockItems
          .alert.alert-warning
            i.fa-solid.fa-exclamation-triangle.me-2
            strong #{item.name}
            |  – only #{item.quantity} left (reorder at 15 units)
      else
        .text-muted
          i.fa-solid.fa-check-circle.text-success.me-2
          | No low stock items. All products have 15 or more units.