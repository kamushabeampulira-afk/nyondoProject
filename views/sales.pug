extends layout

block title
  | Sales – NYONDO Hardware

block content
  .page-heading-center.mb-4
    h1
      i.fa-solid.fa-cart-shopping
      |  Sales Counter
    p.text-muted Select customer, add items, then checkout

  // Customer & distance form
  .section-card.mb-4
    .section-head
      h2
        i.fa-solid.fa-user.me-2(style="color: var(--gold);")
        | Customer & Delivery
    form(method="POST" action="/sales/update-customer")
      .row.g-3
        .col-md-5
          label.form-label Select Customer
          select.form-select(name="customerId")
            option(value="") Walk-in Customer
            each cust in customers
              option(value=cust._id selected=(selectedCustomerId == cust._id)) #{cust.fullName} (#{cust.phone})
          .mt-2
            a.btn-link(href="/sales/new-customer") + New Customer
        .col-md-4
          label.form-label Distance from Nansana (km)
          input.form-control(type="number" name="distance" value=deliveryDistance step="1")
        .col-md-3.align-self-end
          button.btn-primary(type="submit") Update
    if selectedCustomer
      .mt-2.text-success Selected: #{selectedCustomer.fullName}

  // Add item form
  .section-card.mb-4
    .section-head
      h2
        i.fa-solid.fa-cart-plus.me-2(style="color: var(--gold);")
        | Add Item to Cart
    form(method="POST" action="/sales/add-item")
      .row.g-3
        .col-md-6
          label.form-label Product
          select.form-select(name="productId" required)
            option(value="") -- Select Product --
            each prod in products
              option(value=prod._id) #{prod.productName} - #{prod.unitPrice.toLocaleString()} UGX (Stock: #{prod.currentStock})
        .col-md-3
          label.form-label Quantity
          input.form-control(type="number" name="quantity" value="1" min="1")
        .col-md-3.align-self-end
          button.btn-primary(type="submit") Add to Cart

  // Cart display
  .section-card.mb-4
    .section-head
      h2
        i.fa-solid.fa-cart-shopping.me-2(style="color: var(--gold);")
        | Shopping Cart
      form(method="POST" action="/sales/clear-cart" onsubmit="return confirm('Clear entire cart?')")
        button.btn-outline.btn-sm(type="submit") Clear Cart
    if cart && cart.length
      .table-responsive
        table.table.table-bordered
          thead
            tr
              th Item
              th Qty
              th Unit Price (UGX)
              th Total (UGX)
              th
          tbody
            each item, idx in cart
              tr
                td #{item.name}
                td #{item.qty}
                td #{item.price.toLocaleString()}
                td #{(item.price * item.qty).toLocaleString()}
                td
                  form(method="POST" action="/sales/remove-item" style="display:inline")
                    input(type="hidden" name="index" value=idx)
                    button.btn-danger.btn-sm(type="submit") Remove
          tfoot
            tr
              td(colspan="3").text-end.fw-bold Subtotal
              td #{subtotal.toLocaleString()} UGX
              td
            tr
              td(colspan="3").text-end.fw-bold Delivery Fee
              td #{deliveryFee.toLocaleString()} UGX
              td
            tr.table-success
              td(colspan="3").text-end.fw-bold Grand Total
              td #{grandTotal.toLocaleString()} UGX
              td
    else
      p.text-muted Cart is empty.

  // Checkout
  if cart && cart.length
    .section-card
      .section-head
        h2
          i.fa-solid.fa-receipt.me-2(style="color: var(--gold);")
          | Checkout
      form(method="POST" action="/sales/checkout")
        .row.g-3
          .col-md-6
            label.form-label Payment Method
            select.form-select(name="paymentMethod" required)
              option Cash
              option Mobile Money
              option Credit
              option Deposit Scheme
          .col-md-6.align-self-end
            button.btn-success.w-100(type="submit") Complete Sale