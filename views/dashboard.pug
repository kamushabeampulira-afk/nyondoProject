extends layout

block head
  //- link(rel="stylesheet" href="/css/dashboard.css")

block title
  | Dashboard – NYONDO Hardware

block content
  .page-heading-center.mb-4
    if user.role === 'admin'
      h1
        i.fa-solid.fa-chart-line.me-2
        | Admin Dashboard
      p.text-muted Full system overview & key metrics
    else if user.role === 'manager'
      h1
        i.fa-solid.fa-chart-line.me-2
        | Manager Dashboard
      p.text-muted Stock and sales oversight
    else
      h1
        i.fa-solid.fa-cart-shopping.me-2
        | Sales Dashboard
      p.text-muted Quick actions and today's performance

  // ========= KPI CARDS (common for all roles) =========
  .row.g-4.mb-5
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-sack-dollar.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Today's Sales
        h3= (todaySales || 0).toLocaleString() + ' UGX'
        small.text-success
    if user.role === 'admin' || user.role === 'manager'
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-warehouse.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Stock Value
          h3= (stockValue || 0).toLocaleString() + ' UGX'
          small.text-warning
    if user.role === 'admin'
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-hand-holding-dollar.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Credit Balance
          h3= (creditBalance || 0).toLocaleString() + ' UGX'
          small.text-info
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-piggy-bank.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Deposit Members
          h3= (depositMembers || 0)
          small.text-success
    if user.role === 'manager'
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-triangle-exclamation.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Low Stock Items
          h3.text-warning= lowStockCount || 0
          small.text-danger Reorder soon
    if user.role === 'sales' || user.role === 'attendant'
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-receipt.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Transactions Today
          h3= transactionsToday || 0
          small.text-info
      .col-md-3.col-sm-6
        .section-card.metric-card.p-3.text-center
          i.fa-solid.fa-clock.fa-2x.mb-2(style="color: var(--gold);")
          h6.text-muted Pending Invoices
          h3.text-warning= pendingInvoices || 0
          small.text-danger Awaiting payment

  // ========= SALES ATTENDANT SPECIFIC SECTIONS =========
  if user.role === 'sales' || user.role === 'attendant'
    // Big "Start New Sale" button
    .row.g-4.mb-4
      .col-12
        .section-card.text-center
          .section-head
            h2
              i.fa-solid.fa-cart-plus.me-2(style="color: var(--gold);")
              | Quick Action
          .p-3
            a.btn-primary.btn-lg(href="/sales")
              i.fa-solid.fa-arrow-right.me-2
              | Start New Sale

    // Products in stock table
    .section-card.mb-4
      .section-head
        h2
          i.fa-solid.fa-boxes-stacked.me-2(style="color: var(--gold);")
          | Products in Stock
      .table-responsive
        table.data-table
          thead
            tr
              th Product
              th Stock
              th Unit Price (UGX)
          tbody
            if productsInStock && productsInStock.length
              each prod in productsInStock
                tr
                  td #{prod.productName}
                  td #{prod.currentStock}
                  td #{prod.unitPrice.toLocaleString()}
            else
              tr
                td(colspan='3').text-center No products in stock.

    // Recent sales by this attendant
    .section-card
      .section-head
        h2
          i.fa-solid.fa-clock-rotate-left.me-2(style="color: var(--gold);")
          | Your Recent Sales
      .table-responsive
        table.data-table
          thead
            tr
              th Invoice #
              th Customer
              th Total (UGX)
              th Date
          tbody
            if recentSalesAttendant && recentSalesAttendant.length
              each sale in recentSalesAttendant
                tr
                  td #{sale.invoiceNumber}
                  td #{sale.customerName || 'Walk-in'}
                  td #{sale.grandTotal.toLocaleString()}
                  td #{sale.createdAt.toLocaleDateString()}
            else
              tr
                td(colspan='4').text-center No sales yet.

  // ========= ADMIN/MANAGER SPECIFIC SECTIONS =========
  if user.role === 'admin' || user.role === 'manager'
    // Daily Sales Table (replaces chart)
    .section-card.mb-4
      .section-head
        h2
          i.fa-solid.fa-chart-simple.me-2(style="color: var(--gold);")
          | Daily Sales (Last 7 Days)
      .table-responsive
        table.table.table-bordered
          thead
            tr
              th Date
              th Sales (UGX)
          tbody
            each day in dailySales
              tr
                td= day.date
                td= day.total.toLocaleString()

    .row.g-4.mb-4
      if user.role === 'manager'
        .col-md-6
          .section-card
            .section-head
              h2
                i.fa-solid.fa-boxes-stacked.me-2(style="color: var(--gold);")
                | Stock Management
            .p-3.text-center
              p Monitor inventory, add new stock
              a.btn-primary(href="/inventory")
                i.fa-solid.fa-warehouse.me-2
                | Go to Inventory
        .col-md-6
          .section-card
            .section-head
              h2
                i.fa-solid.fa-truck.me-2(style="color: var(--gold);")
                | Delivery Calculator
            .p-3.text-center
              p Estimate delivery fees
              a.btn-outline(href="/transport")
                i.fa-solid.fa-calculator.me-2
                | Transport
      if user.role === 'admin'
        .col-md-4
          .section-card
            .section-head
              h2
                i.fa-solid.fa-credit-card.me-2(style="color: var(--gold);")
                | Supplier Credit
            .p-3.text-center
              p Record credit purchases and payments
              a.btn-primary(href="/supplier-credit")
                i.fa-solid.fa-hand-holding-dollar.me-2
                | Supplier Credit
        .col-md-4
          .section-card
            .section-head
              h2
                i.fa-solid.fa-piggy-bank.me-2(style="color: var(--gold);")
                | Deposit Scheme
            .p-3.text-center
              p Manage members, deposits, pickups
              a.btn-outline(href="/deposit-scheme")
                i.fa-solid.fa-receipt.me-2
                | Deposit Scheme
        .col-md-4
          .section-card
            .section-head
              h2
                i.fa-solid.fa-chart-bar.me-2(style="color: var(--gold);")
                | Reports
            .p-3.text-center
              p View analytics and export data
              a.btn-outline(href="/reports")
                i.fa-solid.fa-chart-line.me-2
                | Reports

    .row.g-4
      if recentSales && recentSales.length
        .col-md-6
          .section-card
            .section-head
              h2
                i.fa-solid.fa-clock-rotate-left.me-2(style="color: var(--gold);")
                | Recent Sales
            .p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead
                    tr
                      th Invoice
                      th Customer
                      th Total (UGX)
                      th Attendant
                  tbody
                    each sale in recentSales
                      tr
                        td= sale.invoiceNumber
                        td= sale.customerName || 'Walk-in'
                        td= sale.grandTotal.toLocaleString()
                        td= sale.attendant ? sale.attendant.fullName : '—'
      if recentStock && recentStock.length
        .col-md-6
          .section-card
            .section-head
              h2
                i.fa-solid.fa-cube.me-2(style="color: var(--gold);")
                | Recent Stock Additions
            .p-0
              .table-responsive
                table.table.table-sm.mb-0
                  thead
                    tr
                      th Product
                      th Quantity
                      th Supplier
                      th Date
                  tbody
                    each tx in recentStock
                      tr
                        td= tx.productName
                        td= tx.quantityAdded
                        td= tx.supplierName || '—'
                        td= tx.createdAt ? tx.createdAt.toLocaleDateString() : '—'

  if user.role === 'admin' && recentDeposits && recentDeposits.length
    .row.g-4.mt-4
      .col-12
        .section-card
          .section-head
            h2
              i.fa-solid.fa-piggy-bank.me-2(style="color: var(--gold);")
              | Recent Deposit Transactions
          .p-0
            .table-responsive
              table.table.table-sm.mb-0
                thead
                  tr
                    th Member
                    th Type
                    th Amount (UGX)
                    th Date
                tbody
                  each tx in recentDeposits
                    tr
                      td= tx.memberId ? tx.memberId.fullName : '—'
                      td
                        if tx.type === 'deposit'
                          span.text-success Deposit
                        else
                          span.text-warning Pickup
                      td
                        if tx.type === 'deposit'
                          | + #{tx.amount.toLocaleString()}
                        else
                          | - #{Math.abs(tx.amount).toLocaleString()}
                      td= tx.createdAt ? tx.createdAt.toLocaleDateString() : '—'