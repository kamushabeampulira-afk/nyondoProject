extends layout

block head
  link(rel="stylesheet" href="/css/record-payment.css")

block title
  | Record Payment – NYONDO Hardware

block content
  .page-heading-center.mb-4
    h1
      i.fa-solid.fa-money-bill-wave
      |  Record Supplier Payment
    p.text-muted Record payments against outstanding invoices

  .form-card.payment-form-card
    form(method="POST" action="/payments/record")
      .mb-3
        label.form-label Select Supplier
        select.form-select(name='supplierId' required onchange='this.form.submit()')
          option(value='') -- Choose Supplier --
          each sup in suppliers
            option(value=sup._id selected=(selectedSupplierId && selectedSupplierId.toString() === sup._id.toString()))= sup.companyName

      if selectedSupplier && outstandingInvoices && outstandingInvoices.length
        .mb-3
          label.form-label Select Invoice
          select.form-select(name='invoiceId' required)
            option(value='') -- Select Invoice --
            each inv in outstandingInvoices
              option(value=inv._id) #{inv.invoiceNumber} - #{inv.outstanding.toLocaleString()} UGX outstanding (Due #{inv.dueDate ? new Date(inv.dueDate).toLocaleDateString() : '—'})

        .mb-3
          label.form-label Payment Amount (UGX) *
          input.form-control(type='number' name='amount' min='1' step='1000' required)

        .mb-3
          label.form-label Payment Method
          select.form-select(name='paymentMethod' required)
            option Cash
            option Bank Transfer
            option Mobile Money

        .mb-3
          label.form-label Payment Date
          input.form-control(type='date' name='paymentDate' value=today)

        .mb-3
          label.form-label Reference / Notes
          input.form-control(type='text' name='reference' placeholder='Optional reference')

        button.btn-primary.w-100(type='submit')
          i.fa-solid.fa-check-circle
          | Record Payment

      else if selectedSupplier && (!outstandingInvoices || outstandingInvoices.length === 0)
        .alert.alert-info No outstanding invoices for this supplier.