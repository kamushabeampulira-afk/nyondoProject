doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Deposit Receipt | Nyondo Hardware
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css")
    style.
      @media print {
        .no-print { display: none !important; }
        body { background: white; padding: 1rem; }
        .receipt-card { box-shadow: none; border: 1px solid #ddd; }
      }
      body {
        background: #f4f6f9;
        font-family: 'Segoe UI', Roboto, sans-serif;
        padding: 2rem 1rem;
      }
      .receipt-card {
        max-width: 500px;
        margin: 0 auto;
        background: white;
        border-radius: 24px;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        overflow: hidden;
      }
      .receipt-header {
        background: #2c3e2b;
        color: white;
        padding: 1.5rem;
        text-align: center;
      }
      .brand-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
      .brand-text h1 { font-size: 1.6rem; font-weight: 700; }
      .brand-text span { font-weight: 400; }
      .receipt-meta {
        background: #f8f9fa;
        padding: 0.75rem;
        border-radius: 16px;
        margin-top: 0.5rem;
      }
      .receipt-body { padding: 1.5rem; }
      hr { margin: 1rem 0; }
      .total-row { font-weight: 700; font-size: 1.2rem; }
      .thankyou { text-align: center; margin-top: 1.5rem; }
      .footer-note {
        font-size: 0.7rem;
        color: #6c757d;
        text-align: center;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px dashed #dee2e6;
      }
  body
    .receipt-card
      .receipt-header
        .brand-icon: i.fas.fa-piggy-bank
        .brand-text
          h1 NYONDO <span>HARDWARE</span>
          p.mb-0 Deposit Scheme Receipt
      .receipt-body
        .receipt-meta
          .d-flex.justify-content-between.mb-2
            span
              i.fas.fa-user
              |  Member:
            strong #{transaction.member.fullName}
          .d-flex.justify-content-between.mb-2
            span
              i.fas.fa-id-card
              |  NIN:
            span #{transaction.member.nin || '—'}
          .d-flex.justify-content-between.mb-2
            span
              i.fas.fa-phone
              |  Phone:
            span #{transaction.member.phone}
          .d-flex.justify-content-between.mb-2
            span
              i.fas.fa-exchange-alt
              |  Type:
            span(class=transaction.type === 'deposit' ? 'text-success' : 'text-warning') #{transaction.type === 'deposit' ? 'DEPOSIT' : 'PICKUP'}
          .d-flex.justify-content-between.mb-2
            span
              i.far.fa-calendar-alt
              |  Date:
            span #{new Date(transaction.createdAt).toLocaleString()}
          .d-flex.justify-content-between
            span
              i.fas.fa-receipt
              |  Transaction ID:
            span #{transaction._id.toString().slice(-6).toUpperCase()}
        hr
        if transaction.type === 'deposit'
          .d-flex.justify-content-between.mb-2
            span Amount Deposited
            span.text-success.fw-bold + #{transaction.amount.toLocaleString()} UGX
        else
          .d-flex.justify-content-between.mb-2
            span Product
            span #{transaction.productDetails.productName}
          .d-flex.justify-content-between.mb-2
            span Quantity
            span #{transaction.productDetails.quantity}
          .d-flex.justify-content-between.mb-2
            span Unit Price
            span #{transaction.productDetails.unitPrice.toLocaleString()} UGX
          .d-flex.justify-content-between.mb-2
            span Total Value
            span.text-warning.fw-bold #{Math.abs(transaction.amount).toLocaleString()} UGX
        hr
        .d-flex.justify-content-between.fw-bold.total-row
          span New Balance
          span #{transaction.balanceAfter.toLocaleString()} UGX
        .thankyou
          p.mb-0.small Recorded by: #{transaction.recordedBy ? transaction.recordedBy.fullName : 'System'}
          p.mb-0 Thank you for using Nyondo Deposit Scheme!
        .footer-note
          i.fas.fa-print
          |  Keep this receipt for your records
      .text-center.p-3.bg-light.no-print
        button.btn.btn-primary.me-2(onclick="window.print()")
          i.fas.fa-print.me-1
          | Print Receipt
        a.btn.btn-outline-secondary(href="/deposit-scheme")
          i.fas.fa-arrow-left.me-1
          | Back to Deposit Scheme