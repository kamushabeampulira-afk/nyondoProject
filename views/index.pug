doctype html
html(lang="en")
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title NYONDO Hardware – Portal
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..800&family=Syne:wght@400..800&display=swap' rel='stylesheet')
    style.
      :root {
        --dark-green: #003300;
        --gold: #f7b32b;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        background: #f4f8f4;
        overflow-x: hidden;
        position: relative;
      }

      /* Background image layer */
      .bg-layer {
        position: fixed;
        inset: 0;
        background-image: url('/images/page.png');
        background-size: cover;
        background-position: center;
        opacity: 0.07;
        z-index: 0;
        pointer-events: none;
      }

      /* Green top bar */
      .top-bar {
        background: var(--dark-green);
        padding: 0.6rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        z-index: 10;
      }
      .top-bar-brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.05em;
      }
      .top-bar-brand i {
        color: var(--gold);
        font-size: 1.2rem;
      }
      .top-bar-tag {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.6);
        font-style: italic;
      }

      /* Hero section */
      .hero {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 5rem 1rem 3rem;
      }

      .brand-logo {
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, var(--gold), #e5a020);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dark-green);
        font-size: 2.5rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 12px 30px rgba(0,51,0,0.2);
        transition: transform 0.3s ease;
      }
      .brand-logo:hover { transform: scale(1.06) rotate(3deg); }

      .hero h1 {
        font-family: 'Syne', sans-serif;
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--dark-green);
        line-height: 1.15;
        margin-bottom: 0.75rem;
      }
      .hero h1 span { color: var(--gold); }

      .hero p {
        font-size: 1.05rem;
        color: #4a6050;
        max-width: 480px;
        margin: 0 auto 0.5rem;
      }

      .hero-divider {
        width: 60px;
        height: 4px;
        background: linear-gradient(90deg, var(--dark-green), var(--gold));
        border-radius: 2px;
        margin: 1.5rem auto 0;
      }

      /* Stats strip */
      .stats-strip {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: center;
        gap: 2.5rem;
        padding: 1.5rem 1rem 2.5rem;
        flex-wrap: wrap;
      }
      .stat-item {
        text-align: center;
      }
      .stat-item strong {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--dark-green);
      }
      .stat-item span {
        font-size: 0.78rem;
        color: #6c8c70;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .stat-divider {
        width: 1px;
        background: #c8ddc8;
        align-self: stretch;
      }

      /* Role cards section */
      .cards-section {
        position: relative;
        z-index: 1;
        padding: 0 1rem 4rem;
      }

      .cards-label {
        text-align: center;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #7a9a7a;
        margin-bottom: 1.5rem;
      }

      .role-card {
        background: var(--dark-green);
        border-radius: 1.5rem;
        padding: 2.25rem 1.5rem 2rem;
        text-align: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        height: 100%;
        border: 1px solid rgba(255,255,255,0.06);
        position: relative;
        overflow: hidden;
      }

      .role-card::before {
        content: '';
        position: absolute;
        top: -40px;
        right: -40px;
        width: 120px;
        height: 120px;
        background: rgba(247,179,43,0.08);
        border-radius: 50%;
      }

      .role-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 24px 40px rgba(0,51,0,0.25);
        background: #004d00;
      }

      .role-icon-wrap {
        width: 68px;
        height: 68px;
        background: rgba(247,179,43,0.15);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        border: 1px solid rgba(247,179,43,0.25);
        transition: background 0.3s;
      }
      .role-card:hover .role-icon-wrap {
        background: rgba(247,179,43,0.25);
      }

      .role-icon-wrap i {
        font-size: 1.8rem;
        color: var(--gold);
      }

      .role-card h4 {
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: white;
      }

      .role-card p {
        font-size: 0.85rem;
        color: rgba(255,255,255,0.55);
        margin-bottom: 1.5rem;
        line-height: 1.5;
      }

      .role-btn {
        background: var(--gold);
        border: none;
        color: var(--dark-green);
        padding: 0.55rem 1.75rem;
        border-radius: 2rem;
        font-weight: 700;
        font-size: 0.88rem;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .role-btn:hover {
        background: white;
        color: var(--dark-green);
        transform: scale(0.97);
      }

      /* Footer */
      .site-footer {
        position: relative;
        z-index: 1;
        background: var(--dark-green);
        color: rgba(255,255,255,0.5);
        text-align: center;
        padding: 1.25rem 1rem;
        font-size: 0.82rem;
      }
      .site-footer span { color: var(--gold); }

      /* Responsive */
      @media (max-width: 768px) {
        .hero h1 { font-size: 2rem; }
        .stats-strip { gap: 1.5rem; }
        .stat-divider { display: none; }
      }

  body
    .bg-layer

    //- Top bar
    .top-bar
      .top-bar-brand
        i.fa-solid.fa-tools
        | NYONDO HARDWARE
      .top-bar-tag Nansana Branch · Est. 2010

    //- Hero
    .hero
      .brand-logo
        i.fa-solid.fa-tools
      h1 Welcome to
        br
        span NYONDO
        |  Hardware
      p Your trusted partner for quality building materials and hardware supplies.
      .hero-divider

    //- Stats strip
    .stats-strip
      .stat-item
        strong 500+
        span Products
      .stat-divider
      .stat-item
        strong 10+
        span Years Experience
      .stat-divider
      .stat-item
        strong 24/7
        span Support

    //- Role cards
    .cards-section
      .container
        p.cards-label Select your role to continue
        .row.g-4.justify-content-center
          .col-md-4.col-sm-6
            .role-card(onclick="location.href='/auth/login'")
              .role-icon-wrap
                i.fa-solid.fa-shield-halved
              h4 Administrator
              p Full system control, user management, and detailed reports
              button.role-btn
                | Login
                i.fa-solid.fa-arrow-right
          .col-md-4.col-sm-6
            .role-card(onclick="location.href='/auth/login'")
              .role-icon-wrap
                i.fa-solid.fa-chart-line
              h4 Manager
              p Inventory oversight, analytics, and stock management
              button.role-btn
                | Login
                i.fa-solid.fa-arrow-right
          .col-md-4.col-sm-6
            .role-card(onclick="location.href='/auth/login'")
              .role-icon-wrap
                i.fa-solid.fa-cart-shopping
              h4 Sales Attendant
              p Point of sale, customer service, and daily transactions
              button.role-btn
                | Login
                i.fa-solid.fa-arrow-right

    //- Footer
    .site-footer
      i.fa-regular.fa-copyright
      |  2026
      span  NYONDO General Hardware LTD.
      |  · Nansana, Kampala · All rights reserved.

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js')