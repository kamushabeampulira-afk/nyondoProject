doctype html
html(lang="en")
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title NYONDO Hardware – Portal
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..800&family=Syne:wght@400..800&family=DM+Sans:wght@300..600&display=swap' rel='stylesheet')
    style.
      body {
        background: linear-gradient(135deg, #f5faf8 0%, #e8f4f0 100%);
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
        position: relative;
        overflow-x: hidden;
      }
      /* Cement/iron bars background – you can replace URL with your own image */
      .bg-pattern {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0.18;
        pointer-events: none;
        z-index: 0;
        background-image: url('/images/page.png');
        background-size: cover;
        background-position: center;
      }
      .brand-logo {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #f7b32b 0%, #e5a020 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e2a2f;
        font-size: 3rem;
        margin: 0 auto 1rem;
        box-shadow: 0 10px 25px -5px rgba(6, 69, 27, 0.2);
        transition: transform 0.3s ease;
      }
      .brand-logo:hover {
        transform: scale(1.05);
      }
      .role-card {
        background: #024802;
        border-radius: 1.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
        height: 100%;
        box-shadow: 0 10px 20px rgba(18, 48, 22, 0.1);
      }
      .role-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 30px rgba(11, 31, 20, 0.2);
      }
      .role-icon {
        font-size: 3rem;
        color: #f7b32b;
        margin-bottom: 1rem;
      }
      .role-btn {
        background: #f7b32b;
        border: none;
        color: #1e2f23;
        padding: 0.5rem 1.5rem;
        border-radius: 2rem;
        margin-top: 1rem;
        font-weight: bold;
        transition: 0.2s;
      }
      .role-btn:hover {
        background: #e5a020;
        transform: translateY(-2px);
      }
      .footer {
        text-align: center;
        margin-top: 4rem;
        color: #043d02;
        font-size: 0.9rem;
      }
  body
    .bg-pattern
    .container.py-5
      .text-center
        .brand-logo
          i.fa-solid.fa-tools
        h1.display-4.fw-bold NYONDO Hardware
        p.lead.text-muted Building solutions to last for Generations
      .row.g-4.justify-content-center.mt-5
        .col-md-4
          .role-card(onclick="location.href='/auth/login'")
            .role-icon
              i.fa-solid.fa-shield-haltered
            h4 Administrator
            p.text-white-50 Full system control & reports
            button.role-btn Login →
        .col-md-4
          .role-card(onclick="location.href='/auth/login'")
            .role-icon
              i.fa-solid.fa-chart-line
            h4 Manager
            p.text-white-50 Analytics & stock management
            button.role-btn Login →
        .col-md-4
          .role-card(onclick="location.href='/auth/login'")
            .role-icon
              i.fa-solid.fa-cart-shopping
            h4 Sales Attendant
            p.text-white-50 Point of sale & customers
            button.role-btn Login →
      .footer
        i.fa-regular.fa-copyright
        |  2026 NYONDO General Hardware LTD. Secure portal.