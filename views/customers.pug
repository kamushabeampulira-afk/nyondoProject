extends layout

block head
  link(rel="stylesheet" href="/css/customers.css")

block title
  | Customers – NYONDO Hardware

block content
  .page-heading-center.mb-4
    h1
      i.fa-solid.fa-users
      |  Customer Management
    p.text-muted Manage customer information

  // Stats Cards (optional)
  .row.g-4.mb-4
    .col-md-3.col-sm-6
      .section-card.metric-card.p-3.text-center
        i.fa-solid.fa-users.fa-2x.mb-2(style="color: var(--gold);")
        h6.text-muted Total Customers
        h3= totalCustomers || 0

  // Add Customer Form (always visible, no toggle)
  .form-card.mb-4
    h4.mb-3
      i.fa-solid.fa-user-plus.me-2(style="color: var(--gold);")
      | Register New Customer
    form(method="POST" action="/customers")
      .row.g-3
        .col-md-6
          label.form-label Full Name *
          input.form-control(type='text' name='fullName' required)
        .col-md-6
          label.form-label Phone Number *
          input.form-control(type='tel' name='phone' pattern='^(07|\\+2567)\\d{8}$' required)
        .col-md-6
          label.form-label NIN (Optional)
          input.form-control(type='text' name='nin')
        .col-md-6
          label.form-label Email (Optional)
          input.form-control(type='email' name='email')
        .col-12
          label.form-label Address
          textarea.form-control(rows='2' name='address')
        .col-md-6
          label.form-label Customer Type
          select.form-select(name='customerType')
            option Walk-in
            option Contractor
            option Wholesale
            option Deposit Scheme
        .col-md-6
          label.form-label Credit Limit (UGX)
          input.form-control(type='number' name='creditLimit' placeholder='0' min='0')
      .mt-4
        button.btn-primary(type='submit')
          i.fa-solid.fa-save
          |  Save Customer

  // Customers Table
  .section-card
    .section-head
      h2
        i.fa-solid.fa-list.me-2(style="color: var(--gold);")
        | Customer List
    .table-responsive
      table.data-table
        thead
          tr
            th Name
            th Phone
            th NIN
            th Type
            th Total Purchases (UGX)
            th Actions
        tbody
          if customers && customers.length
            each cust in customers
              tr
                td
                  i.fa-solid.fa-user.me-2(style="color: var(--gold);")
                  = cust.fullName
                td= cust.phone
                td= cust.nin || '—'
                td= cust.customerType
                td.amount= cust.totalPurchases ? cust.totalPurchases.toLocaleString() : '0'
                td
                  a(href=`/customers/${cust._id}`)
                    i.fa-regular.fa-eye.me-2
                  a(href=`/customers/${cust._id}/edit`)
                    i.fa-regular.fa-pen-to-square
          else
            tr
              td(colspan='6').text-center No customers found.