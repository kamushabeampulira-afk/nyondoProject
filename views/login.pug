extends layout

block head
  style.
    .login-wrapper {
      min-height: calc(100vh - 120px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .login-card {
      background: white;
      border-radius: 1.5rem;
      box-shadow: 0 20px 35px -10px rgba(0,0,0,0.15);
      overflow: hidden;
      max-width: 480px;
      width: 100%;
      transition: transform 0.2s;
    }
    .login-card:hover {
      transform: translateY(-3px);
    }
    .login-header {
      background: var(--dark-bg, #1e2a2f);  /* uses your sidebar color variable */
      padding: 2rem 1.5rem;
      text-align: center;
      position: relative;
    }
    .login-header .brand-icon {
      width: 70px;
      height: 70px;
      background: var(--gold, #f7b32b);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      font-size: 2rem;
      color: var(--dark-bg, #1e2a2f);
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
    .login-header h3 {
      color: white;
      font-weight: 600;
      margin-bottom: 0.25rem;
    }
    .login-header p {
      color: rgba(255,255,255,0.8);
      font-size: 0.9rem;
    }
    .login-body {
      padding: 2rem;
    }
    .form-group {
      margin-bottom: 1.5rem;
    }
    .form-group label {
      font-weight: 500;
      color: #1e2a2f;
      margin-bottom: 0.5rem;
      display: block;
    }
    .input-icon {
      position: relative;
    }
    .input-icon i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #aaa;
      font-size: 1rem;
    }
    .input-icon input {
      width: 100%;
      padding: 0.8rem 1rem 0.8rem 2.5rem;
      border: 1px solid #e2e8f0;
      border-radius: 0.75rem;
      font-size: 1rem;
      transition: 0.2s;
    }
    .input-icon input:focus {
      border-color: var(--gold);
      outline: none;
      box-shadow: 0 0 0 3px rgba(247,179,43,0.2);
    }
    .btn-login {
      background: var(--dark-bg, #1e2a2f);
      color: white;
      border: none;
      border-radius: 0.75rem;
      padding: 0.8rem;
      font-weight: 600;
      width: 100%;
      transition: 0.2s;
      font-size: 1rem;
    }
    .btn-login:hover {
      background: var(--gold);
      color: var(--dark-bg, #1e2a2f);
    }
    .login-footer {
      text-align: center;
      padding: 1rem 2rem 1.5rem;
      border-top: 1px solid #edf2f7;
      background: #fafbfc;
    }
    .login-footer a {
      color: var(--gold);
      text-decoration: none;
      font-weight: 500;
    }
    .login-footer a:hover {
      text-decoration: underline;
    }
    .alert-custom {
      background: #fee2e2;
      border-left: 4px solid #ef4444;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

  link(rel="stylesheet" href="/css/login.css")

block title
  | Login – NYONDO Hardware

block content
  .login-wrapper
    .login-card
      .login-header
        .brand-icon
          i.fa-solid.fa-tools
        h3 Welcome Back
        p Sign in to continue to the portal
      .login-body
        if error_msg
          .alert-custom
            i.fa-solid.fa-circle-exclamation.me-2
            = error_msg
        if success_msg
          .alert.alert-success.alert-dismissible.fade.show
            i.fa-solid.fa-check-circle.me-2
            = success_msg
        form(method="POST" action="/auth/login")
          .form-group
            label Email Address
            .input-icon
              i.fa-solid.fa-envelope
              input(type="email" name="email" placeholder="admin@nyondo.com" required)
          .form-group
            label Password
            .input-icon
              i.fa-solid.fa-lock
              input(type="password" name="password" placeholder="••••••••" required)
          button.btn-login(type="submit")
            i.fa-solid.fa-arrow-right-to-bracket.me-2
            | Login
      .login-footer
        | Don't have an account? 
        a(href="/signup") Create one